{
    "name": "cappy-monorepo",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "typecheck": "npm run typecheck --workspaces --if-present",
        "test": "vitest run",
        "dev": "npm run dev -w cappy"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.7.0",
        "tsx": "^4.19.0",
        "vitest": "^2.1.0"
    }
}
